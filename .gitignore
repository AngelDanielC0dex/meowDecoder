# Root .gitignore. The deployable app lives in web/ (which has its own
# web/.gitignore for build output).
#
# The entire training/ folder is kept OUT of the repo — the web app uses only the
# exported ONNX models in web/public/models/. Training scripts and source code
# live locally but are not needed for deployment and should not be on GitHub.
training/

# --- Python environments & caches ---
**/.venv/
**/__pycache__/
*.pyc
**/.pytest_cache/
**/.ruff_cache/
*.egg-info/

# --- OS cruft ---
.DS_Store
Thumbs.db
