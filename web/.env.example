# ============================================================================
# MeowDecoder — environment variables. Copy to `.env.local` and fill in.
# Never commit real secrets. Variables WITHOUT the NEXT_PUBLIC_ prefix are
# server-only and must never reach the browser bundle.
# ============================================================================

# --- Database (server only) -------------------------------------------------
# Postgres connection string (e.g. Supabase). Required for accounts/sync.
DATABASE_URL=postgres://user:password@localhost:5432/meowdecoder

# --- Auth.js (server only) --------------------------------------------------
# Cookie/session signing secret. Generate with:  npx auth secret
AUTH_SECRET=generate-with-npx-auth-secret
# SMTP server for the passwordless magic-link emails (Gmail, Resend, Mailtrap…).
AUTH_EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
AUTH_EMAIL_FROM=hello@meowdecoder.app

# --- Cloudflare Turnstile (anti-bot on feedback writes) ---------------------
# Public site key (browser widget) + secret key (server verification).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- AI assistant (server only) ---------------------------------------------
# OpenAI key for the premium AI assistant (model gpt-4o-mini). Leave empty to
# disable the assistant gracefully (endpoint returns "not configured").
OPENAI_API_KEY=

# --- Admin panel (server only) ----------------------------------------------
# Allowlist of admin emails (comma or space separated). A signed-in user whose
# email matches gets access to /admin (feature-flag toggles). Empty = no admins
# (panel locked down). Matched case-insensitively against the session email.
ADMIN_EMAILS=

# --- Public -----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://meowdecoder.app

# Accounts / auth experience. "true" lights up sign-in, history, cats and
# corrections (anonymous users can analyze but must sign in to correct/keep
# history). Leave unset/"false" to keep the fully-local, no-account mode.
# Turn on ONLY once DATABASE_URL + AUTH_SECRET + AUTH_EMAIL_* are configured
# and the adapter migration has been applied (npm run db:migrate).
NEXT_PUBLIC_ACCOUNTS_ENABLED=false

# Ads. "false" disables every ad slot (side rails + contextual). Defaults to on.
NEXT_PUBLIC_ADS_ENABLED=true

# ONNX engine activation. Leave empty (or unset) to use the proven heuristic
# baseline — the AI model is currently frozen. Set to "/models" (or a CDN URL)
# to load the published ONNX model; if its manifest is missing or incompatible
# the app falls back to the heuristic automatically. Enable in production ONLY
# after the model passes the regression suite against the baseline (see
# docs/model-contract.md).
NEXT_PUBLIC_MODEL_BASE_URL=
