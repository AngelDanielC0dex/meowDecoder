# --- Server only (never NEXT_PUBLIC) ---
DATABASE_URL=postgres://user:password@localhost:5432/meowdecoder
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
AUTH_EMAIL_FROM=hello@meowdecoder.app

# --- Public ---
NEXT_PUBLIC_SITE_URL=https://meowdecoder.app

# ONNX engine activation. Empty/unset → the proven heuristic baseline runs.
# Set to "/models" (or a CDN URL) to load the published ONNX model; if its
# manifest is missing or incompatible the app falls back to the heuristic
# automatically. Enable in production ONLY after the model passes the
# regression suite against the baseline (see docs/model-contract.md).
NEXT_PUBLIC_MODEL_BASE_URL=/models
